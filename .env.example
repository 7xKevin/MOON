SERVICE_MODE=bot
HOST=::
PORT=3000
PREFIX=!
WAKE_WORD=moon
REQUIRE_WAKE_WORD=true
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
APP_BASE_URL=http://localhost:3000
SESSION_SECRET=replace_this_with_a_long_random_secret
DASHBOARD_SUPER_ADMIN_IDS=
DATABASE_URL=
DATA_DIR=D:\MOON\data
CONTROLLER_USER_ID=
# Groq is the recommended hosted STT path for Railway.
GROQ_API_KEY=
GROQ_STT_MODEL=whisper-large-v3
GROQ_STT_URL=https://api.groq.com/openai/v1/audio/transcriptions
# Local Windows example paths. Optional when using Groq.
WHISPER_CPP_PATH=C:\tools\whisper.cpp\build\bin\Release\whisper-cli.exe
WHISPER_MODEL_PATH=C:\tools\whisper.cpp\models\ggml-small.en.bin
WHISPER_LANGUAGE=en
WHISPER_PROMPT=Discord voice commands like lock, unlock, mute, unmute, kick, drag people here, and move people to named voice channels like general or waiting room. User names may include punctuation or repeated vowels.
WHISPER_BEAM_SIZE=5
WHISPER_BEST_OF=5
WHISPER_TEMPERATURE=0
TEMP_DIR=D:\MOON\tmp
TRANSCRIPTION_SILENCE_MS=1200
COMMAND_COOLDOWN_MS=2500
DEBUG_TRANSCRIPTS=false


