SERVICE_MODE=bot
HOST=::
PORT=3000
PREFIX=!
WAKE_WORD=moon
REQUIRE_WAKE_WORD=true
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
APP_BASE_URL=http://localhost:3000
SESSION_SECRET=replace_this_with_a_long_random_secret
DASHBOARD_SUPER_ADMIN_IDS=
DATABASE_URL=
DATA_DIR=D:\MOON\data
CONTROLLER_USER_ID=
# Local Windows example paths. In Render, Dockerfile.bot sets Linux defaults automatically.
WHISPER_CPP_PATH=C:\tools\whisper.cpp\build\bin\Release\whisper-cli.exe
WHISPER_MODEL_PATH=C:\tools\whisper.cpp\models\ggml-small.en.bin
WHISPER_LANGUAGE=en
WHISPER_PROMPT=Discord voice commands like lock, unlock, mute, unmute, kick, and drag users here.
WHISPER_BEAM_SIZE=5
WHISPER_BEST_OF=5
WHISPER_TEMPERATURE=0
TEMP_DIR=D:\MOON\tmp
TRANSCRIPTION_SILENCE_MS=1200
COMMAND_COOLDOWN_MS=2500
DEBUG_TRANSCRIPTS=false
