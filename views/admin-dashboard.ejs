<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/static/styles.css" />
    <script src="/static/theme.js" defer></script>
    <script src="/static/app.js" defer></script>
    <script src="/static/guild-settings.js" defer></script>
  </head>
  <body class="admin-page admin-minimal">
    <div class="layout">
      <aside class="sidebar">
        <a class="brand" href="/dashboard">
          <span class="moon-logo brand-logo" aria-hidden="true">
            <span class="moon-logo-ring"></span>
            <span class="moon-logo-core"></span>
            <span class="moon-logo-orbit moon-logo-orbit-one"></span>
            <span class="moon-logo-orbit moon-logo-orbit-two"></span>
          </span>
          <span class="brand-copy">
            <strong>MOON ADMIN</strong>
            <span><%= currentUser.globalName || currentUser.username %></span>
          </span>
        </a>

        <div class="sidebar-section">
          <nav class="sidebar-nav">
            <a class="nav-item active" href="/dashboard">Runtime</a>
            <% if (userDashboardUrl) { %>
              <a class="nav-item" href="<%= userDashboardUrl %>" target="_blank" rel="noreferrer">Public dashboard</a>
            <% } %>
            <a class="nav-item" href="/logout">Log out</a>
          </nav>
        </div>
      </aside>

      <main class="main">
        <header class="topbar admin-topbar">
          <div>
            <h1 class="page-title">Runtime</h1>
            <div class="meta">Minimal global controls.</div>
          </div>
          <div class="actions">
            <button class="theme-toggle" type="button" data-theme-toggle>
              Theme: <span data-theme-label>Light</span>
            </button>
            <% if (userDashboardUrl) { %>
              <a class="button" href="<%= userDashboardUrl %>" target="_blank" rel="noreferrer">Public dashboard</a>
            <% } %>
            <a class="button primary" href="/logout">Log out</a>
          </div>
        </header>

        <% if (typeof saved !== "undefined" && saved) { %>
          <div class="notice notice-overlay success" data-auto-dismiss>Saved.</div>
        <% } %>

        <form method="post" action="/dashboard" class="form-shell" data-settings-form>
          <input type="hidden" name="csrfToken" value="<%= csrfToken %>" />

          <section class="card admin-panel">
            <div class="card-body">
              <div class="badge-row">
                <span class="eyebrow">global state</span>
                <span class="badge <%= settings.globalBotEnabled ? 'live' : '' %>">
                  <%= settings.globalBotEnabled ? 'bot on' : 'bot off' %>
                </span>
                <span class="badge <%= settings.userDashboardEnabled ? 'live' : '' %>">
                  <%= settings.userDashboardEnabled ? 'dashboard on' : 'dashboard off' %>
                </span>
              </div>
              <div class="toggle-grid admin-toggle-grid">
                <label class="toggle admin-toggle">
                  <input type="checkbox" name="globalBotEnabled" <%= settings.globalBotEnabled ? "checked" : "" %> />
                  <span class="toggle-copy">
                    <span>Enable bot globally</span>
                    <small>Pause or resume command execution everywhere.</small>
                  </span>
                </label>
                <label class="toggle admin-toggle">
                  <input type="checkbox" name="userDashboardEnabled" <%= settings.userDashboardEnabled ? "checked" : "" %> />
                  <span class="toggle-copy">
                    <span>Enable public dashboard</span>
                    <small>Hide or expose the normal guild dashboard.</small>
                  </span>
                </label>
              </div>
            </div>
          </section>

          <section class="card admin-panel">
            <div class="card-body form-section">
              <div class="admin-section-head">
                <h2 class="section-title">Speech providers</h2>
                <span class="meta">Shown automatically from configured keys and local runtime.</span>
              </div>

              <div class="admin-provider-list">
                <% if (!providerCatalog.length) { %>
                  <div class="meta">No speech providers are configured in this environment yet.</div>
                <% } %>
                <% providerCatalog.forEach((provider) => { %>
                  <article class="admin-provider-row">
                    <div class="admin-provider-main">
                      <label class="toggle admin-toggle admin-provider-toggle">
                        <input type="checkbox" name="<%= provider.toggleName %>" <%= provider.enabled ? "checked" : "" %> />
                        <span class="toggle-copy">
                          <span><%= provider.label %></span>
                          <small><%= provider.description %></small>
                        </span>
                      </label>
                    </div>
                    <div class="admin-provider-config">
                      <% if (provider.models.length) { %>
                        <label>
                          Model
                          <select name="<%= provider.modelName %>">
                            <% provider.models.forEach((model) => { %>
                              <option value="<%= model %>" <%= provider.currentModel === model ? "selected" : "" %>><%= model %></option>
                            <% }) %>
                          </select>
                        </label>
                      <% } else { %>
                        <div class="meta">Model: <code><%= provider.currentModel %></code></div>
                      <% } %>
                    </div>
                  </article>
                <% }) %>
              </div>

              <% if (providerCatalog.length) { %>
                <div class="field-grid">
                  <label>
                    Primary provider
                    <select name="preferredSttProvider">
                      <% providerCatalog.forEach((provider) => { %>
                        <option value="<%= provider.key %>" <%= settings.preferredSttProvider === provider.key ? 'selected' : '' %>><%= provider.label %></option>
                      <% }) %>
                    </select>
                    <span class="field-help">The bot tries this provider first, then falls back through the enabled providers.</span>
                  </label>
                </div>
              <% } %>
            </div>
          </section>

          <section class="card admin-panel">
            <div class="card-body form-section">
              <div class="admin-section-head">
                <h2 class="section-title">Defaults</h2>
                <span class="meta">Applied to runtime baselines and new guild profiles.</span>
              </div>

              <div class="toggle-grid admin-toggle-grid">
                <label class="toggle admin-toggle">
                  <input type="checkbox" name="defaultRequireWakeWord" <%= settings.defaultRequireWakeWord ? "checked" : "" %> />
                  <span class="toggle-copy">
                    <span>Require wake word</span>
                    <small>Baseline wake-word requirement.</small>
                  </span>
                </label>
              </div>

              <div class="field-grid">
                <label>
                  Default wake word
                  <input type="text" name="defaultWakeWord" value="<%= settings.defaultWakeWord %>" />
                </label>
                <label>
                  Silence cutoff (ms)
                  <input type="text" name="defaultTranscriptionSilenceMs" value="<%= settings.defaultTranscriptionSilenceMs %>" />
                </label>
              </div>

              <div class="field-grid">
                <label>
                  Command cooldown (ms)
                  <input type="text" name="defaultCommandCooldownMs" value="<%= settings.defaultCommandCooldownMs %>" />
                </label>
              </div>
            </div>
          </section>

          <div class="save-bar" data-save-bar>
            <div class="save-bar-copy">
              <strong>Unsaved changes.</strong>
              <span>Save to update the live runtime.</span>
            </div>
            <div class="inline-actions">
              <button class="button" type="button" data-reset-form>Cancel</button>
              <button class="primary" type="submit">Save</button>
            </div>
          </div>
        </form>
      </main>
    </div>
  </body>
</html>
