<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/static/styles.css" />
    <script src="/static/theme.js" defer></script>
    <script src="/static/app.js" defer></script>
  </head>
  <body class="admin-page admin-minimal">
    <div class="layout">
      <aside class="sidebar">
        <a class="brand" href="/">
          <span class="moon-logo brand-logo" aria-hidden="true">
            <span class="moon-logo-ring"></span>
            <span class="moon-logo-core"></span>
            <span class="moon-logo-orbit moon-logo-orbit-one"></span>
            <span class="moon-logo-orbit moon-logo-orbit-two"></span>
          </span>
          <span class="brand-copy">
            <strong>MOON ADMIN</strong>
            <span>developer console</span>
          </span>
        </a>

        <div class="sidebar-section">
          <nav class="sidebar-nav">
            <a class="nav-item active" href="/">Overview</a>
            <% if (userDashboardUrl) { %>
              <a class="nav-item" href="<%= userDashboardUrl %>" target="_blank" rel="noreferrer">Public dashboard</a>
            <% } %>
          </nav>
        </div>
      </aside>

      <main class="main">
        <header class="topbar admin-topbar">
          <div>
            <h1 class="page-title">MOON ADMIN</h1>
            <div class="meta">Global control.</div>
          </div>
          <div class="actions">
            <button class="theme-toggle" type="button" data-theme-toggle>
              Theme: <span data-theme-label>Light</span>
            </button>
            <% if (loggedIn) { %>
              <a class="button primary" href="/dashboard">Open</a>
            <% } else { %>
              <a class="button primary" href="/login">Sign in</a>
            <% } %>
          </div>
        </header>

        <% if (typeof error !== "undefined" && error) { %>
          <div class="notice error"><%= error %></div>
        <% } %>

        <section class="card admin-panel">
          <div class="card-body admin-copy">
            <div class="badge-row">
              <span class="eyebrow">super-admin only</span>
              <span class="badge">discord oauth</span>
            </div>
            <p class="admin-intro">
              Manage the live bot, public dashboard availability, and speech runtime defaults from one place.
            </p>
            <div class="inline-actions">
              <% if (loggedIn) { %>
                <a class="button primary" href="/dashboard">Go to console</a>
              <% } else { %>
                <a class="button primary" href="/login">Continue with Discord</a>
              <% } %>
            </div>
          </div>
        </section>
      </main>
    </div>
  </body>
</html>
