<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/static/styles.css" />
    <script src="/static/theme.js" defer></script>
  </head>
  <body>
    <div class="layout">
      <aside class="sidebar">
        <a class="brand" href="/dashboard">
          <span class="brand-mark">M</span>
          <span class="brand-copy">
            <strong>MOON Control</strong>
            <span><%= currentUser.globalName || currentUser.username %></span>
          </span>
        </a>

        <div class="sidebar-section">
          <p class="sidebar-label">Navigation</p>
          <nav class="sidebar-nav">
            <a class="nav-item active" href="/dashboard">Servers</a>
            <% if (botInviteUrl) { %>
              <a class="nav-item" href="<%= botInviteUrl %>" target="_blank" rel="noreferrer">Invite MOON</a>
            <% } %>
            <a class="nav-item" href="/logout">Log Out</a>
          </nav>
        </div>
      </aside>

      <main class="main">
        <header class="topbar">
          <div>
            <h1 class="page-title">Servers</h1>
            <div class="meta">
              Showing <%= guilds.length %> server<%= guilds.length === 1 ? "" : "s" %> where your Discord
              account has admin access.
            </div>
          </div>
          <div class="actions">
            <button class="theme-toggle" type="button" data-theme-toggle>
              Theme: <span data-theme-label>Light</span>
            </button>
            <% if (botInviteUrl) { %>
              <a class="button" href="<%= botInviteUrl %>" target="_blank" rel="noreferrer">Invite MOON</a>
            <% } %>
            <a class="button primary" href="/logout">Log Out</a>
          </div>
        </header>

        <section class="card" style="margin-bottom: 16px;">
          <div class="card-body">
            <span class="eyebrow">Guild selection</span>
            <h2 class="section-title" style="margin-top: 10px;">Choose a server and edit the bot rules.</h2>
            <p class="section-lead">
              Each guild gets its own access list, safety toggles, and preferred channels.
            </p>
          </div>
        </section>

        <% if (!guilds.length) { %>
          <section class="card">
            <div class="card-body">
              <h2 class="section-title">No accessible servers</h2>
              <p class="section-lead">
                Discord did not return any guilds where your account has <code>Manage Server</code> or
                <code>Administrator</code>. If that seems wrong, log out and log in again after checking your roles.
              </p>
            </div>
          </section>
        <% } %>

        <section class="guild-grid">
          <% guilds.forEach((guild) => { %>
            <article class="card guild-card">
              <div class="card-body">
                <div class="badge-row" style="margin-bottom: 12px;">
                  <span class="badge live">Admin access</span>
                </div>
                <h3 class="guild-name"><%= guild.name %></h3>
                <div class="meta">Guild ID: <code><%= guild.id %></code></div>
                <div class="inline-actions" style="margin-top: 14px;">
                  <a class="button primary" href="/guilds/<%= guild.id %>">Open Settings</a>
                </div>
              </div>
            </article>
          <% }) %>
        </section>
      </main>
    </div>
  </body>
</html>
