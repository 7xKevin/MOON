<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/static/styles.css" />
    <script src="/static/theme.js" defer></script>
  </head>
  <body>
    <div class="layout">
      <aside class="sidebar">
        <a class="brand" href="/dashboard">
          <span class="brand-mark">M</span>
          <span class="brand-copy">
            <strong>MOON Control</strong>
            <span><%= guild.name %></span>
          </span>
        </a>

        <div class="sidebar-section">
          <p class="sidebar-label">Navigation</p>
          <nav class="sidebar-nav">
            <a class="nav-item" href="/dashboard">Back to servers</a>
            <a class="nav-item active" href="/guilds/<%= guild.id %>">Guild settings</a>
            <a class="nav-item" href="/logout">Log Out</a>
          </nav>
        </div>
      </aside>

      <main class="main">
        <header class="topbar">
          <div>
            <h1 class="page-title"><%= guild.name %></h1>
            <div class="meta">Guild ID: <code><%= guild.id %></code></div>
          </div>
          <div class="actions">
            <button class="theme-toggle" type="button" data-theme-toggle>
              Theme: <span data-theme-label>Light</span>
            </button>
            <a class="button" href="/dashboard">Back</a>
            <a class="button primary" href="/logout">Log Out</a>
          </div>
        </header>

        <% if (saved) { %>
          <div class="notice">Settings saved.</div>
        <% } %>

        <section class="card">
          <div class="card-body form-shell">
            <div>
              <div class="badge-row">
                <span class="eyebrow">Guild configuration</span>
                <span class="badge <%= settings.botPresent ? 'live' : '' %>">
                  <%= settings.botPresent ? 'MOON is already in this server' : 'MOON is not in this server yet' %>
                </span>
              </div>
              <h2 class="section-title" style="margin-top: 10px;">Define exactly who MOON listens to.</h2>
              <p class="section-lead">
                The session starter always keeps control. Discord admins keep access too. Everything else here is optional.
              </p>
            </div>

            <form method="post" action="/guilds/<%= guild.id %>" class="form-shell">
              <input type="hidden" name="guildName" value="<%= guild.name %>" />
              <input type="hidden" name="csrfToken" value="<%= csrfToken %>" />

              <section class="form-section">
                <h3 class="section-title">Bot state</h3>
                <div class="toggle-grid">
                  <label class="toggle">
                    <input type="checkbox" name="botEnabled" <%= settings.botEnabled ? "checked" : "" %> />
                    <span class="toggle-copy">
                      <span>Enable MOON in this guild</span>
                      <small>Turns command handling on or off for the whole server.</small>
                    </span>
                  </label>
                  <label class="toggle">
                    <input type="checkbox" name="transcriptionEnabled" <%= settings.transcriptionEnabled ? "checked" : "" %> />
                    <span class="toggle-copy">
                      <span>Enable voice decoding</span>
                      <small>When off, MOON stays in voice but ignores speech entirely.</small>
                    </span>
                  </label>
                  <label class="toggle">
                    <input type="checkbox" name="debugTranscripts" <%= settings.debugTranscripts ? "checked" : "" %> />
                    <span class="toggle-copy">
                      <span>Show transcript debug posts</span>
                      <small>Only post recognized command transcripts. Keep this off during normal use.</small>
                    </span>
                  </label>
                </div>
              </section>

              <section class="form-section">
                <h3 class="section-title">Voice recognition</h3>
                <div class="toggle-grid">
                  <label class="toggle">
                    <input type="checkbox" name="requireWakeWord" <%= settings.requireWakeWord ? "checked" : "" %> />
                    <span class="toggle-copy">
                      <span>Require wake word</span>
                      <small>Only execute commands that begin with the configured wake word.</small>
                    </span>
                  </label>
                </div>
                <div class="field-grid">
                  <label>
                    Wake word
                    <input type="text" name="wakeWord" value="<%= settings.wakeWord %>" />
                    <span class="field-help">Examples: <code>moon</code>, <code>nova</code>, <code>assistant</code>.</span>
                  </label>
                  <label>
                    Silence cutoff (ms)
                    <input type="text" name="transcriptionSilenceMs" value="<%= settings.transcriptionSilenceMs %>" />
                    <span class="field-help">How long MOON waits after silence before sending audio to Whisper.</span>
                  </label>
                </div>
                <div class="field-grid">
                  <label>
                    Command cooldown (ms)
                    <input type="text" name="commandCooldownMs" value="<%= settings.commandCooldownMs %>" />
                    <span class="field-help">Minimum delay between accepted voice commands in this guild.</span>
                  </label>
                </div>
              </section>

              <section class="form-section">
                <h3 class="section-title">Access</h3>
                <div class="field-grid">
                  <label>
                    Admin user IDs
                    <textarea name="adminUserIds"><%= settings.adminUserIds.join('\n') %></textarea>
                    <span class="field-help">One Discord user ID per line. These users can start or stop MOON.</span>
                  </label>
                  <label>
                    Voice command user IDs
                    <textarea name="commandUserIds"><%= settings.commandUserIds.join('\n') %></textarea>
                    <span class="field-help">Users allowed to speak commands while in the same voice channel.</span>
                  </label>
                </div>
                <div class="field-grid">
                  <label>
                    Voice command role IDs
                    <textarea name="allowedRoleIds"><%= settings.allowedRoleIds.join('\n') %></textarea>
                    <span class="field-help">Anyone with one of these roles can issue voice commands.</span>
                  </label>
                  <label>
                    Preferred text channel ID
                    <input type="text" name="preferredTextChannelId" value="<%= settings.preferredTextChannelId %>" />
                    <span class="field-help">Status messages go here if set.</span>
                  </label>
                </div>
                <div class="field-grid">
                  <label>
                    Preferred voice channel ID
                    <input type="text" name="preferredVoiceChannelId" value="<%= settings.preferredVoiceChannelId %>" />
                    <span class="field-help">Reserved for future auto-join behavior.</span>
                  </label>
                </div>
              </section>

              <section class="form-section">
                <h3 class="section-title">Allowed actions</h3>
                <div class="toggle-grid">
                  <label class="toggle">
                    <input type="checkbox" name="commandDragEnabled" <%= settings.commandDragEnabled ? "checked" : "" %> />
                    <span class="toggle-copy">
                      <span>Drag / move</span>
                      <small>Move users between voice channels.</small>
                    </span>
                  </label>
                  <label class="toggle">
                    <input type="checkbox" name="commandMuteEnabled" <%= settings.commandMuteEnabled ? "checked" : "" %> />
                    <span class="toggle-copy">
                      <span>Mute / unmute</span>
                      <small>Server mute voice users.</small>
                    </span>
                  </label>
                  <label class="toggle">
                    <input type="checkbox" name="commandKickEnabled" <%= settings.commandKickEnabled ? "checked" : "" %> />
                    <span class="toggle-copy">
                      <span>Kick / disconnect</span>
                      <small>Remove users from voice chat.</small>
                    </span>
                  </label>
                  <label class="toggle">
                    <input type="checkbox" name="commandLockEnabled" <%= settings.commandLockEnabled ? "checked" : "" %> />
                    <span class="toggle-copy">
                      <span>Lock / unlock</span>
                      <small>Change VC join permissions.</small>
                    </span>
                  </label>
                </div>
              </section>

              <div class="inline-actions">
                <button class="primary" type="submit">Save Settings</button>
                <% if (settings.botPresent) { %>
                  <span class="button disabled">Already Invited</span>
                <% } else if (inviteUrl) { %>
                  <a class="button" href="<%= inviteUrl %>" target="_blank" rel="noreferrer">Invite MOON</a>
                <% } %>
              </div>
            </form>
          </div>
        </section>
      </main>
    </div>
  </body>
</html>

